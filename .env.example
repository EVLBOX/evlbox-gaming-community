# Gaming Community in a Box — Environment Configuration
# Generated by setup.sh — you shouldn't need to edit this manually.
# To change services: evlbox enable <service> / evlbox disable <service>
# To change routing: evlbox setup

# =============================================================================
# PROFILES — comma-separated list of enabled optional services
# Options: forum, voice, wiki, paste, blog
# =============================================================================
COMPOSE_PROFILES=forum,voice,wiki,paste

# =============================================================================
# DOMAIN & ROUTING
# Per-service URLs — set by setup.sh (express or custom mode)
# =============================================================================
DOMAIN=example.com
ADMIN_EMAIL=admin@example.com
STOAT_URL=chat.example.com
FORUM_URL=forum.example.com
GHOST_URL=
BOOKSTACK_URL=wiki.example.com
PASTE_URL=paste.example.com
ROOT_URL=example.com
ROOT_TARGET=stoat

# =============================================================================
# MARIADB (shared by forum, blog, wiki)
# =============================================================================
MARIADB_ROOT_PASSWORD=CHANGE_ME

# =============================================================================
# FLARUM (profile: forum)
# =============================================================================
FLARUM_DB_NAME=flarum
FLARUM_DB_USER=flarum
FLARUM_DB_PASSWORD=CHANGE_ME
FLARUM_ADMIN_USER=admin
FLARUM_ADMIN_PASSWORD=CHANGE_ME
FLARUM_ADMIN_EMAIL=admin@example.com
FLARUM_BASE_URL=https://forum.example.com

# =============================================================================
# GHOST (profile: blog)
# =============================================================================
GHOST_DB_NAME=ghost
GHOST_DB_USER=ghost
GHOST_DB_PASSWORD=CHANGE_ME

# =============================================================================
# BOOKSTACK (profile: wiki)
# =============================================================================
BOOKSTACK_APP_KEY=base64:CHANGE_ME
BOOKSTACK_DB_NAME=bookstack
BOOKSTACK_DB_USER=bookstack
BOOKSTACK_DB_PASSWORD=CHANGE_ME

# =============================================================================
# MUMBLE (profile: voice)
# =============================================================================
MUMBLE_SUPERUSER_PASSWORD=CHANGE_ME
